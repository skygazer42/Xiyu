# ============================================================
# Xiyu 政务会议默认栈 - 环境变量示例（推荐）
# ============================================================
#
# ✅ 唯一对外入口（Web UI + API）：
#   http://<server-ip>:${PORT}
#
# ✅ 默认端口（可改）：18200
#
# 说明：
# - 本项目默认用 `docker-compose.yml` 启动整套栈（Router + 多后端 + 降噪 + 说话人）。
# - 除 Router 外，其它服务仅在 Docker 网络内互通，不对外暴露端口（更安全、更不乱）。
# - 可选：先运行 `./scripts/prefetch_models_docker.sh` 触发权重下载/预热，再正式对外启服务。
#

# ------------------------------------------------------------
# 对外端口（唯一需要放行的端口）
# ------------------------------------------------------------
PORT=18200
DEBUG=false

# ------------------------------------------------------------
#（可选）容器内下载模型用代理
# ------------------------------------------------------------
HTTP_PROXY=
HTTPS_PROXY=
ALL_PROXY=
NO_PROXY=localhost,127.0.0.1,::1
http_proxy=
https_proxy=
all_proxy=
no_proxy=localhost,127.0.0.1,::1

# ------------------------------------------------------------
#（可选）HuggingFace Hub 镜像（huggingface.co 不可达时）
# ------------------------------------------------------------
HF_ENDPOINT=https://hf-mirror.com

# ------------------------------------------------------------
#（可选）Docker build 阶段 PyPI 镜像（构建 ONNX 镜像时有用）
# ------------------------------------------------------------
PIP_INDEX_URL=https://mirrors.aliyun.com/pypi/simple/
PIP_TRUSTED_HOST=mirrors.aliyun.com

# ------------------------------------------------------------
# Qwen3-ASR（远程 ASR vLLM）
# ------------------------------------------------------------
# 默认：更准的 1.7B（更吃显存）
QWEN3_MODEL_ID=Qwen/Qwen3-ASR-1.7B
QWEN3_MAX_MODEL_LEN=16384
# 单卡同时跑 Qwen3 + Whisper + ClearVoice：建议先用 0.45（更稳）
QWEN3_GPU_MEMORY_UTILIZATION=0.45
QWEN3_ASR_API_KEY=EMPTY
QWEN3_ASR_TIMEOUT_S=60
# 权重来源：modelscope | huggingface
MODEL_SOURCE=modelscope

# ------------------------------------------------------------
# Router 路由策略（默认不启用 VibeVoice）
# ------------------------------------------------------------
ROUTER_SHORT_BACKEND=qwen3
ROUTER_LONG_BACKEND=qwen3
ROUTER_LONG_AUDIO_THRESHOLD_S=60
ROUTER_FORCE_VIBEVOICE_WHEN_WITH_SPEAKER=false

# ------------------------------------------------------------
# 说话人（external diarizer / pyannote）
# ------------------------------------------------------------
SPEAKER_UNSUPPORTED_BEHAVIOR=ignore
SPEAKER_EXTERNAL_DIARIZER_ENABLE=true
SPEAKER_EXTERNAL_DIARIZER_TIMEOUT_S=180
SPEAKER_EXTERNAL_DIARIZER_MAX_TURN_DURATION_S=45
SPEAKER_EXTERNAL_DIARIZER_MAX_TURNS=1000

# HuggingFace Token（pyannote 可能需要 gated 权限）
HF_TOKEN=
DIARIZER_DEVICE=cpu
DIARIZER_MODEL=pyannote/speaker-diarization-3.1
DIARIZER_WARMUP_ON_STARTUP=true
# 可选：约束会议人数提升稳定性（三选一，优先级 NUM > MIN/MAX）
DIARIZER_NUM_SPEAKERS=
DIARIZER_MIN_SPEAKERS=
DIARIZER_MAX_SPEAKERS=

# ------------------------------------------------------------
# ClearVoice 降噪（默认 MossFormer2_48000Hz）
# ------------------------------------------------------------
# 注意：ClearVoice 需要 ClearerVoice-Studio 代码可被 import：
# - 推荐：在宿主机准备好目录并挂载（下方默认路径）
# - 或者在镜像内 `pip install clearvoice`（更重，不推荐作为默认）
CLEARVOICE_ENABLE=true
CLEARVOICE_STUDIO_DIR=/data/ClearerVoice-Studio/clearvoice
CLEARVOICE_MODEL=MossFormer2_48000Hz
# 用 GPU 更快但占 VRAM；显存紧张可改回 true
CLEARVOICE_FORCE_CPU=false
CLEARVOICE_DEVICE=cuda
CLEARVOICE_NGPU=1
CLEARVOICE_NCPU=4
# 单次 ClearVoice 服务允许的最大时长（秒）；超长会议走分块链路
CLEARVOICE_SERVICE_MAX_DURATION_S=600.0
# 启动即预热（会尽量触发下载/加载权重）
CLEARVOICE_WARMUP_ON_STARTUP=true
CLEARVOICE_CHUNK_DURATION_S=30.0
CLEARVOICE_OVERLAP_DURATION_S=0.5
CLEARVOICE_SERVICE_TIMEOUT_S=600.0
CLEARVOICE_SERVICE_HEALTH_TIMEOUT_S=2.0

# ------------------------------------------------------------
# 各后端设备分配（默认单卡）
# ------------------------------------------------------------
PYTORCH_DEVICE=cuda
PYTORCH_NGPU=1
PYTORCH_NCPU=4

SENSEVOICE_DEVICE=cuda
SENSEVOICE_NGPU=1
SENSEVOICE_NCPU=4
SENSEVOICE_MODEL=iic/SenseVoiceSmall
SENSEVOICE_LANGUAGE=zh

WHISPER_DEVICE=cuda
WHISPER_NGPU=1
WHISPER_NCPU=4
WHISPER_MODEL=large-v3
WHISPER_LANGUAGE=zh
WHISPER_DOWNLOAD_ROOT=/app/data/models/whisper
WHISPER_COMPUTE_TYPE=int8_float16
WHISPER_VAD_FILTER=true
WHISPER_VAD_MIN_SILENCE_DURATION_MS=500

ONNX_DEVICE=cpu
ONNX_NGPU=0
ONNX_NCPU=8

# ------------------------------------------------------------
# 热启动 / 预热（各 Xiyu 容器）
# ------------------------------------------------------------
WARMUP_ON_STARTUP=true
WARMUP_AUDIO_DURATION=1.0

# ------------------------------------------------------------
# 热词（默认文件在 data/hotwords/）
# ------------------------------------------------------------
HOTWORDS_FILE=hotwords.txt
HOTWORDS_CONTEXT_FILE=hotwords-context.txt
HOTWORDS_THRESHOLD=0.85
HOTWORD_INJECTION_ENABLE=true
HOTWORD_INJECTION_MAX=50
HOTWORD_WATCH_ENABLE=true
HOTWORD_WATCH_DEBOUNCE=3.0

# ------------------------------------------------------------
# 文本后处理（政务会议推荐）
# ------------------------------------------------------------
ITN_ENABLE=true
QJ2BJ_ENABLE=true
GOV_FORMAT_ENABLE=true

# ------------------------------------------------------------
# LLM（可选：全量优化/润色）
# ------------------------------------------------------------
LLM_ENABLE=false
LLM_BACKEND=auto
LLM_MODEL=
LLM_BASE_URL=
LLM_API_KEY=
